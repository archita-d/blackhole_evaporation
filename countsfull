import numpy as np
import matplotlib.pyplot as plt

G = 6.67e-11
c = 3e8
h = 6.626e-34
k = 1.381e-23

def radius(M):
    return 2 * G * M / c**2

def temperature(M):
    return (h / (2 * 3.14159)) * c**3 / (8 * 3.14159 * G * M * k)

def power(M):
    r_s = radius(M)
    A = 4 * 3.14159 * r_s**2
    T = temperature(M)
    return 5.670e-8 * A * T**4   # this is the stefan-boltzmann constant

# from blackbody photon function 
MeV_to_joules = 1.602176634e-13 # it doesnt work if i dont do this bc of unit purposes
def b_function(E_MeV, T):
    E = E_MeV * MeV_to_joules
    x = E / (k*T)
    denominator = np.expm1(x)
    denominator = np.where(denominator == 0, 1e-300, denominator)
    return (2 * E**2) / (h**3 * c**2) / denominator

# ^ this is going to avoid having a 0 in the denominator when the temperature gets extremely large
# step one from slide eight where we  multiplying by the sq-cm of the blackbody surface
def step1(M, E):
    T = temperature(M)
    r_s = radius(M)
    surface_area_cm2 = 4 * 3.14159 * (r_s * 100)**2  
    p_function_value = b_function(E, T)
    return p_function_value * surface_area_cm2

# step 2 is to multiply by the time sample of the gamma-ray detectr (1 microsec)
def step2(M, E, time_sample):
    step1_result = step1(M, E)
    return step1_result * time_sample

# step 3 is to integrate the blackbody function for each of the energy ranges
def step3(M, E_low, E_high, time_sample):
    T = temperature(M)
    r_s = radius(M)
    surface_area_cm2 = 4 * 3.14159 * (r_s * 100)**2  

    E_values = np.linspace(E_low, E_high, 200)
    p_function_values = b_function(E_values, T)
    integrated_range = np.trapezoid(p_function_values, E_values)

    gamma_rays = integrated_range * surface_area_cm2 * time_sample

    return gamma_rays

# step 4 is to multiply by how much area the detector subtends at distance D - idk what D is yet 
def step4(M, E_low, E_high, time_sample, D, A_detector):
    gamma_rays = step3(M, E_low, E_high, time_sample)
    detector = A_detector / (4 * 3.14159 * D**2)
    return gamma_rays * detector
    
# the energy bin array 

energy_bin = np.logspace(np.log10(0.001), np.log10(1.0), 33) #conversion is basically 0.001 mev = 1 kev and then 33 edges 

def gamma_array(M, energy_bin, time_sample, D, A_detector):
    counts = []
    for i in range(len(energy_bin) - 1):
        E_low = energy_bin[i]
        E_high = energy_bin[i + 1]
        count = step4(M, E_low, E_high, time_sample, D, A_detector)
        counts.append(count)
    return np.array(counts) # this loop was given by claude bc i couldnt figure out how to repeat for 32 bins

# so now im going to run the full evaporation to get counts per over time

def fullevap (M0, energy_bin, time_sample, D, A_detector, max_steps=100000, mass_cutoff=1e-6, save_every=50, xraythres=1e6):
 #basically xraythreshold is the temperature where the bin counting starts
    M=M0
    time_elapsed = 0
    n_bins = len(energy_bin) -1 #they hold edges so theres act 33 of them and then the actual num of bins is one less (32)

    cumulative_counts = np.zeros(n_bins) #this is going to create 32 zeros array for each energy bin which starts at nothing
    historytime = [] #the empty lists
    historycounts = []

    fstime = [None] * n_bins #will get filled with an actual time value when each bin crosses 1 count

    for i in range(max_steps):
        P=power(M)
        dt=0.001 * M* c**2/P # i alr kinda did this in the other adaptive sim
        T = temperature(M)

#now im going to run the bin calculation once T is hot enough to emit the xrays

        if T >= xraythres:
            step_counts = gamma_array(M, energy_bin, dt, D, A_detector)
            cumulative_counts += step_counts

    #this essentially checks if any bin crossed 1 count for the 1st time
            for b in range(n_bins):
                if fstime[b] is None and cumulative_counts[b] >= 1.0:
                    fstime[b] = time_elapsed

        if M < mass_cutoff:
            print("Mass reached 0 at step", i, "time:", time_elapsed, "s")
            break

#same sort of mass update as before
        dM = (P*dt) / c**2
        M = M - dM
        time_elapsed += dt

# save some so we dont end up with a huge history list
# this was given by claude bc i could not figure out the loop
        if i % save_every == 0:
            historytime.append(time_elapsed)
            historycounts.append(cumulative_counts.copy()) 

    return np.array(historytime), np.array(historycounts), cumulative_counts, fstime


